# Gloam EditorConfig
# https://editorconfig.org

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.kt]
indent_size = 4
max_line_length = 120

[*.kts]
indent_size = 4
max_line_length = 140

[*.md]
indent_size = 2
trim_trailing_whitespace = false
max_line_length = 120

[*.yml]
indent_size = 2

[*.json]
indent_size = 2

[*.xml]
indent_size = 4

[*.html]
indent_size = 2

[*.properties]
indent_size = 4

[*.pro]
indent_size = 2
