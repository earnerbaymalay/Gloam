# Auto-detect text files and normalize line endings
* text=auto

*.kt text eol=lf
*.kts text eol=lf
*.java text eol=lf
*.xml text eol=lf
*.html text eol=lf
*.css text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.properties text eol=lf
*.pro text eol=lf

*.png binary
*.jpg binary
*.gif binary
*.svg binary
*.ico binary
*.jar binary
*.aar binary
*.so binary
*.deb binary
